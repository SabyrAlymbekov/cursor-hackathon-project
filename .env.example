# Supabase — get these from https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: service role key (server-side only, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App base URL (used for generating shareable bingo links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
